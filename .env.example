# ======================================================
# Bot WA Absen PKL — Environment Variables
# ======================================================
# Copy file ini menjadi .env dan isi nilainya

# ─── Firebase ──────────────────────────────────────────
# PILIH SALAH SATU cara konfigurasi Firebase:

# Cara 1 (LOKAL): Taruh file serviceAccountKey.json di folder ini
# → Tidak perlu isi FIREBASE_SERVICE_ACCOUNT_JSON

# Cara 2 (RAILWAY/RENDER): Paste isi JSON service account di sini
# → Copy seluruh isi serviceAccountKey.json, paste sebagai satu baris
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Storage bucket Firebase kamu (cek di firebase.js project kamu)
FIREBASE_STORAGE_BUCKET=device-streaming-d7bccff2.firebasestorage.app

# ─── Bot Settings ───────────────────────────────────────
# Keyword yang harus ada di caption foto untuk absen (default: absen)
KEYWORD_ABSEN=absen

# Nomor WA yang boleh absen (pisah koma, tanpa +/spasi)
# Kosongkan = semua orang bisa absen
# Contoh: ALLOWED_NUMBERS=628123456789,628987654321
ALLOWED_NUMBERS=6285810192529
